# ===== DATABASE =====
# Railway автоматически создаёт DATABASE_URL переменную
# На локальной машине используйте MONGODB_URI:
MONGODB_URI=mongodb://admin:password123@localhost:27017/testing-system?retryWrites=true&w=majority&authSource=admin

# ===== JWT SECRET =====
JWT_SECRET=your-secret-key-change-this-in-production

