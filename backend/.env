# ===== DATABASE =====
# Для Docker MongoDB (docker-compose up -d):
MONGODB_URI=mongodb://admin:password123@localhost:27017/testing-system?retryWrites=true&w=majority&authSource=admin

# Для локального MongoDB:
# MONGODB_URI=mongodb://localhost:27017/testing-system

# Для MongoDB Atlas (облачное):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/testing-system?retryWrites=true&w=majority

# ===== JWT =====
JWT_SECRET=my-super-secret-jwt-key-2026
JWT_EXPIRE=7d

# ===== SERVER =====
PORT=5001
NODE_ENV=development

# ===== CORS =====
FRONTEND_URL=http://localhost:3000
